# =====================================================
# Nutrixa Backend — Environment Variables
# =====================================================
# Copy this file to .env for local development
# Set these as environment variables on your hosting platform for production

# Server
PORT=5001

# Database — Replace with MongoDB Atlas URI for production
# Get a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nutrixa?retryWrites=true&w=majority

# CORS — Set to your deployed frontend URL in production
CORS_ORIGIN=https://your-frontend-domain.com

# App URL (used for internal links)
APP_URL=https://your-backend-domain.com

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# FatSecret Nutrition API
FATSECRET_CLIENT_ID=your_fatsecret_client_id_here
FATSECRET_CLIENT_SECRET=your_fatsecret_client_secret_here

# USDA FoodData Central
USDA_API_KEY=your_usda_api_key_here

# NVIDIA API (optional)
NVIDIA_API=your_nvidia_api_key_here
